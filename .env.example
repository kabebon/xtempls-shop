# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://xtempls.ru
BACKEND_URL=http://backend:8000

# ===== Manager Notifications =====
# Получи свой chat_id написав @userinfobot
MANAGER_CHAT_ID=123456789

# ===== Internal Bot↔Backend Security =====
BOT_SECRET=change_me_random_secret_string


# ===== Database =====
POSTGRES_USER=xtempls
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=xtempls_db
DATABASE_URL=postgresql+asyncpg://xtempls:change_me_strong_password@postgres:5432/xtempls_db

# ===== Auth (JWT) =====
SECRET_KEY=change_me_to_a_very_long_random_string_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== First Admin Account =====
ADMIN_DEFAULT_LOGIN=admin
ADMIN_DEFAULT_PASSWORD=change_me_strong_admin_password

# ===== Environment =====
ENVIRONMENT=production
ALLOWED_ORIGINS=https://xtempls.ru
